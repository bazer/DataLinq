<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\DataLinq.PlatformCompatibility.Smoke\DataLinq.PlatformCompatibility.Smoke.csproj" />
  </ItemGroup>

  <ItemGroup>
    <TrimmerRootAssembly Include="DataLinq" />
    <TrimmerRootAssembly Include="DataLinq.SQLite" />
    <TrimmerRootAssembly Include="Remotion.Linq" />
  </ItemGroup>

</Project>
